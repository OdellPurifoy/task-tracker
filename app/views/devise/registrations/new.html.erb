<div class="container">
  <div class="row">
    <div class="col align-self-center">
      <h2>Sign Up</h2>
      <%= simple_form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
      <%= f.error_notification %>
      <div class="form-group">
        <%= f.input :first_name, required: true, autofocus: true, input_html: { class:"input" }, wrapper: false, label_html: { class:"label" } %>
      </div>
      <div class="form-group">
        <%= f.input :last_name, required: true, autofocus: true, input_html: { class:"input" }, wrapper: false, label_html: { class:"label" } %>
      </div>
      <div class="form-group">
        <%= f.input :email, required: true, autofocus: true, input_html: { class:"input" }, wrapper: false, label_html: { class:"label" } %>
      </div>
      <div class="form-group">
        <%= f.input :password, required: true, autofocus: true, input_html: { class:"input" }, wrapper: false, label_html: { class:"label" } %>
      </div>
      <div class="form-group">
        <%= f.button :submit, "Submit", class:"btn btn-primary" %>
      </div>
    </div>
  <% end %>
  <%= render "devise/shared/links" %>
</div>
</div>